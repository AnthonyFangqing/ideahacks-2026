{
	"name": "ideahacks",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -n frontend,backend -c cyan,green \"pnpm dev:frontend\" \"pnpm dev:backend\"",
		"dev:frontend": "pnpm --filter web dev",
		"dev:backend": "cd apps/backend && uv run python main.py",
		"build": "pnpm -r build",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run --passWithNoTests",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.33.2",
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
